{
  "version": "0.2.0",
  "configurations": [
    // ============================================================
    // 1) DEPURAR EL SERVIDOR DE NEXT.JS (Node.js)
    // ============================================================
    {
      "name": "Next: Node",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 9229,
      "sourceMaps": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },

    // ============================================================
    // 2) DEPURAR EL CLIENTE (React/Next) EN CHROME
    // ============================================================
    {
      "name": "Next: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "port": 9222
    }
  ]
}
